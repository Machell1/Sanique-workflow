{
  "name": "saniques-workspace",
  "productName": "Sanique's workspace",
  "version": "2.7.0",
  "description": "Sanique's workspace — personal case-management workspace.",
  "author": {
    "name": "Sanique Richards",
    "email": "williamsmachell@gmail.com"
  },
  "main": "electron/main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env CLAW_DEV=1 electron electron/main.cjs",
    "build:web": "tsc --noEmit && vite build",
    "build:icon": "node scripts/generate-icon.cjs",
    "build": "npm run build:icon && npm run build:web",
    "rebuild:native": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "prefetch:wincodesign": "python scripts/prefetch-wincodesign.py",
    "dist": "npm run prefetch:wincodesign && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --x64",
    "qa": "cross-env ELECTRON_RUN_AS_NODE=1 \"%LOCALAPPDATA%\\Programs\\saniques-workspace\\Sanique's workspace.exe\" scripts/qa-harness.cjs",
    "start": "electron electron/main.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "diff": "^9.0.0",
    "docx": "^9.6.1",
    "dompurify": "^3.4.3",
    "electron": "30.5.1",
    "electron-builder": "^25.1.8",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  }
}
